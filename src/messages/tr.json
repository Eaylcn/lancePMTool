    "education": {
      "title": "Temel KPI'lar",
      "subtitle": "Mobil oyun endüstrisinin en önemli metriklerini öğren",
      "dau": {
        "name": "DAU (Daily Active Users)",
        "definition": "Bir günde oyunu oynayan benzersiz kullanıcı sayısı.",
        "formula": "Günlük benzersiz oturum açan kullanıcılar",
        "why": "Oyunun günlük etkileşim gücünü gösterir. Düşen DAU, retention sorununa işaret eder.",
        "range": "Hyper-casual: 100K-1M+ | Casual: 50K-500K | Mid-core: 10K-200K"
      },
      "mau": {
        "name": "MAU (Monthly Active Users)",
        "definition": "Bir ay içinde oyunu oynayan benzersiz kullanıcı sayısı.",
        "formula": "Aylık benzersiz oturum açan kullanıcılar",
        "why": "Toplam kullanıcı tabanının büyüklüğünü ölçer. Monetization ve yatırımcı metrikleri için temel.",
        "range": "Hyper-casual: 1M-10M+ | Casual: 500K-5M | Mid-core: 100K-2M"
      },
      "arpdau": {
        "name": "ARPDAU (Average Revenue Per DAU)",
        "definition": "Günlük aktif kullanıcı başına ortalama gelir.",
        "formula": "Günlük Gelir / DAU",
        "why": "Monetization verimliliğinin en kritik metriği. Genre'a göre büyük farklılık gösterir.",
        "range": "Hyper-casual: $0.02-0.10 | Casual: $0.05-0.25 | RPG: $0.10-0.70 | Strategy: $0.15-0.90"
      },
      "ltv": {
        "name": "LTV (Lifetime Value)",
        "definition": "Bir kullanıcının oyundaki yaşam boyu toplam değeri.",
        "formula": "ARPDAU × Ortalama Kullanıcı Ömrü (gün)",
        "why": "Kullanıcı edinim bütçesini belirler. LTV > CPI ise oyun sürdürülebilir.",
        "range": "Hyper-casual: $0.10-1.00 | Casual: $1-10 | Mid-core: $5-50+"
      },
      "cpi": {
        "name": "CPI (Cost Per Install)",
        "definition": "Bir yeni kullanıcı edinme maliyeti.",
        "formula": "Reklam Harcaması / Toplam Yükleme",
        "why": "UA (User Acquisition) verimliliğini ölçer. LTV/CPI oranı > 1 olmalı.",
        "range": "Hyper-casual: $0.05-0.50 | Casual: $0.30-3.00 | RPG: $1-8 | Strategy: $1.50-10"
      },
      "retention": {
        "name": "Retention (D1/D7/D30)",
        "definition": "Yükleme sonrası 1., 7. ve 30. günde geri dönen kullanıcı oranı.",
        "formula": "Geri Dönen Kullanıcılar / Toplam Yükleyenler × 100",
        "why": "Oyunun yapışkanlığını ve uzun vadeli sağlığını ölçer. D1 > 40% genellikle iyi sinyaldir.",
        "range": "D1: 25-55% | D7: 8-32% | D30: 3-20% (genre'a göre değişir)"
      },
      "stickiness": {
        "name": "Stickiness (DAU/MAU)",
        "definition": "Aktif kullanıcıların ne kadar düzenli oynadığını ölçer.",
        "formula": "DAU / MAU × 100",
        "why": "Yüksek stickiness = kullanıcılar her gün dönüyor. %20+ genelde iyi.",
        "range": "Hyper-casual: %10-28 | Casual: %12-32 | RPG: %15-40 | Strategy: %18-42"
      },
      "arpu": {
        "name": "ARPU (Average Revenue Per User)",
        "definition": "Aylık aktif kullanıcı başına ortalama gelir.",
        "formula": "Aylık Gelir / MAU",
        "why": "Toplam kullanıcı tabanının parasal değerini gösterir.",
        "range": "Genre ve monetization modeline göre büyük farklılık gösterir"
      },
      "sessionLength": {
        "name": "Ortalama Oturum Süresi",
        "definition": "Kullanıcının bir oturumda ortalama oyun süresi.",
        "formula": "Toplam Oturum Süresi / Toplam Oturum Sayısı",
        "why": "Etkileşim derinliğini ölçer. Kısa oturumlar düşük etkileşime işaret edebilir.",
        "range": "Hyper-casual: 2-7 dk | Casual: 5-20 dk | Mid-core: 10-40 dk"
      },
      "sessionsPerDay": {
        "name": "Günlük Oturum Sayısı",
        "definition": "Bir kullanıcının günde ortalama kaç kez oyunu açtığı.",
        "formula": "Günlük Toplam Oturumlar / DAU",
        "why": "Alışkanlık döngüsünün gücünü gösterir. Yüksek sayı = güçlü retention mekanikleri.",
        "range": "Hyper-casual: 2-7 | Casual: 2-7 | RPG: 2-6 | Strategy: 2-6"
      }
    },
